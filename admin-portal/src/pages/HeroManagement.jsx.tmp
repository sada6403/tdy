import React, { useState, useEffect } from 'react';
import { 
    Plus, Edit2, Trash2, CheckCircle, XCircle, 
    ArrowUp, ArrowDown, Image as ImageIcon, Sparkles, Monitor, Tablet,
    Layout, Save, X, Eye, EyeOff, ShieldCheck
} from 'lucide-react';
import { adminHeroService } from '../services/api/adminHero';

const HeroManagement = () => {
    const [slides, setSlides] = useState([]);
    const [loading, setLoading] = useState(true);
    const [showModal, setShowModal] = useState(false);
    const [editingSlide, setEditingSlide] = useState(null);
    const [previewMode, setPreviewMode] = useState(false);
    const [uploading, setUploading] = useState(false);
    const [showConfirmPopup, setShowConfirmPopup] = useState(false);
    const [confirmationInput, setConfirmationInput] = useState('');
    
    const [formData, setFormData] = useState({
        title: '',
        titleHighlight: '',
        subtitle: '',
        badgeText: '',
        backgroundImage: '',
        primaryButtonText: 'Apply Now',
        primaryButtonLink: '/company/nf-plantation/login',
        secondaryButtonText: 'View Plans',
        secondaryButtonLink: '/company/nf-plantation/investment-plans',
        supportStripText: '',
        trustLabel: 'Asset Backed',
        order: 0,
        isActive: true,
        animationEnabled: true,
        visualMode: 'standard',
        accentColor: 'emerald',
        fontFamily: 'Outfit',
        titleStyle: 'uppercase',
        titleWeight: '900',
        alignment: 'left',
        titleSize: '64px',
        subtitleSize: '18px',
        titleColor: '#ffffff',
        subtitleColor: 'rgba(255,255,255,0.8)',
        highlightColor: '#10b981',
        buttonColor: '#10b981',
        motionType: 'slide-up'
    });

    useEffect(() => {
        fetchSlides();
    }, []);

    const fetchSlides = async () => {
        try {
            setLoading(true);
            const response = await adminHeroService.getHeroSlides();
            if (response.success) {
                setSlides(response.data);
            }
        } catch (error) {
            console.error('Error fetching slides:', error);
        } finally {
            setLoading(false);
        }
    };

    const handleOpenModal = (slide = null) => {
        if (slide) {
            setEditingSlide(slide);
            setFormData({ ...slide });
        } else {
            setEditingSlide(null);
            setFormData({
                title: '',
                titleHighlight: '',
                subtitle: '',
                badgeText: '',
                backgroundImage: '',
                primaryButtonText: 'Apply Now',
                primaryButtonLink: '/company/nf-plantation/login',
                secondaryButtonText: 'View Plans',
                secondaryButtonLink: '/company/nf-plantation/investment-plans',
                supportStripText: '',
                trustLabel: 'Asset Backed',
                order: slides.length + 1,
                isActive: true,
                animationEnabled: true,
                visualMode: 'standard',
                accentColor: 'emerald'
            });
        }
        setShowModal(true);
    };

    const handleSubmit = (e) => {
        if (e) e.preventDefault();
        setConfirmationInput('');
        setShowConfirmPopup(true);
    };

    const handleFinalConfirm = async () => {
        if (confirmationInput.toLowerCase() !== 'confirm') {
            alert('Please type "confirm" to verify the action.');
            return;
        }

        try {
            if (editingSlide) {
                await adminHeroService.updateHeroSlide(editingSlide._id, formData);
            } else {
                await adminHeroService.createHeroSlide(formData);
            }
            setShowConfirmPopup(false);
            setShowModal(false);
            fetchSlides();
        } catch (error) {
            console.error('Error saving slide:', error);
            alert('Error saving hero slide. Please check server logs.');
        }
    };

    const handleDelete = async (id) => {
        if (window.confirm('Are you sure you want to delete this hero slide?')) {
            try {
                await adminHeroService.deleteHeroSlide(id);
                fetchSlides();
            } catch (error) {
                console.error('Error deleting slide:', error);
            }
        }
    };

    const toggleStatus = async (slide) => {
        try {
            await adminHeroService.updateHeroSlide(slide._id, { ...slide, isActive: !slide.isActive });
            fetchSlides();
        } catch (error) {
            console.error('Error toggling status:', error);
        }
    };

    const handleFileUpload = async (e) => {
        const file = e.target.files[0];
        if (!file) return;

        // Check file size (limit to 5MB for base64)
        if (file.size > 5 * 1024 * 1024) {
            alert('File is too large. Please select an image under 5MB.');
            return;
        }

        const reader = new FileReader();
        reader.onloadstart = () => setUploading(true);
        reader.onload = (event) => {
            setFormData(prev => ({ ...prev, backgroundImage: event.target.result }));
            setUploading(false);
        };
        reader.onerror = () => {
            alert('Failed to read file.');
            setUploading(false);
        };
        reader.readAsDataURL(file);
    };

    return (
        <div style={{ padding: '40px' }}>
            {/* Header */}
            <div style={{ 
                display: 'flex', 
                justifyContent: 'space-between', 
                alignItems: 'center', 
                marginBottom: '40px',
                backgroundColor: 'white',
                padding: '32px',
                borderRadius: '24px',
                boxShadow: '0 4px 20px rgba(0,0,0,0.05)'
            }}>
                <div>
                    <h1 style={{ fontSize: '28px', fontWeight: '800', color: '#1e293b', letterSpacing: '-0.5px' }}>Hero Billboard Management</h1>
                    <p style={{ color: '#64748b', fontSize: '14px', marginTop: '4px', fontWeight: '500' }}>Control the premium customer website hero section content and visuals.</p>
                </div>
                <button 
                    onClick={() => handleOpenModal()}
                    style={{ 
                        backgroundColor: 'var(--primary)', 
                        color: 'white', 
                        padding: '12px 24px', 
                        borderRadius: '14px', 
                        fontWeight: '700',
                        display: 'flex',
                        alignItems: 'center',
                        gap: '8px',
                        fontSize: '14px',
                        boxShadow: '0 10px 15px -3px rgba(16, 185, 129, 0.2)'
                    }}>
                    <Plus size={18} /> Create New Slide
                </button>
            </div>

            {/* Slide List */}
            <div style={{ display: 'grid', gap: '20px' }}>
                {loading ? (
                    <p>Loading slides...</p>
                ) : slides.length === 0 ? (
                    <div className="card" style={{ textAlign: 'center', padding: '100px' }}>
                        <ImageIcon size={48} style={{ color: '#cbd5e1', marginBottom: '20px' }} />
                        <h3 style={{ color: '#475569' }}>No Hero Slides Found</h3>
                        <p style={{ color: '#94a3b8' }}>Create your first hero banner to start managing the homepage.</p>
                    </div>
                ) : (
                    slides.map((slide) => (
                        <div key={slide._id} className="card" style={{ 
                            display: 'flex', 
                            alignItems: 'center', 
                            gap: '32px', 
                            padding: '24px',
                            borderLeft: `6px solid ${slide.isActive ? 'var(--primary)' : '#e2e8f0'}`,
                            transition: 'all 0.3s ease'
                        }}>
                            <div style={{ 
                                width: '160px', 
                                height: '90px', 
                                borderRadius: '16px', 
                                overflow: 'hidden',
display: 'flex', 
                                backgroundColor: '#f1f5f9',
                                flexShrink: 0,
                                position: 'relative'
                            }}>
                                <img src={slide.backgroundImage} alt={slide.title} style={{ width: '100%', height: '100%', objectFit: 'cover' }} />
                                {!slide.isActive && (
                                    <div style={{ 
                                        position: 'absolute', 
                                        inset: 0, 
                                        backgroundColor: 'rgba(255,255,255,0.7)',
                                        display: 'flex',
                                        alignItems: 'center',
                                        justifyContent: 'center'
                                    }}>
                                        <EyeOff size={20} color="#94a3b8" />
                                    </div>
                                )}
                            </div>
                            
                            <div style={{ flex: 1 }}>
                                <div style={{ display: 'flex', alignItems: 'center', gap: '12px', marginBottom: '8px' }}>
                                    <span style={{ 
                                        fontSize: '10px', 
                                        fontWeight: '800', 
                                        textTransform: 'uppercase', 
                                        letterSpacing: '1px',
                                        color: slide.isActive ? 'var(--primary)' : '#64748b',
                                        backgroundColor: slide.isActive ? 'rgba(16, 185, 129, 0.1)' : '#f1f5f9',
                                        padding: '4px 8px',
                                        borderRadius: '6px'
                                    }}>
                                        {slide.badgeText || 'No Badge'}
                                    </span>
                                    <span style={{ color: '#94a3b8', fontSize: '12px' }}>Order: #{slide.order}</span>
                                </div>
                                <h3 style={{ fontSize: '18px', fontWeight: '800', color: '#1e293b', marginBottom: '4px' }}>
                                    {slide.title}
                                </h3>
                                <p style={{ color: '#64748b', fontSize: '13px', lineHeight: '1.5', maxLines: 2, overflow: 'hidden' }}>{slide.subtitle}</p>
                            </div>

                            <div style={{ display: 'flex', gap: '12px' }}>
                                <button 
                                    onClick={() => toggleStatus(slide)}
                                    title={slide.isActive ? 'Deactivate' : 'Activate'}
                                    style={{ 
                                        width: '44px', 
                                        height: '44px', 
                                        borderRadius: '12px', 
                                        display: 'flex', 
                                        alignItems: 'center', 
                                        justifyContent: 'center',
                                        backgroundColor: slide.isActive ? 'rgba(16, 185, 129, 0.1)' : '#f1f5f9',
                                        color: slide.isActive ? 'var(--primary)' : '#64748b',
                                        border: 'none',
                                        cursor: 'pointer'
                                    }}>
                                    {slide.isActive ? <CheckCircle size={20} /> : <XCircle size={20} />}
                                </button>
                                <button 
                                    onClick={() => handleOpenModal(slide)}
                                    title="Edit Slide"
                                    style={{ 
                                        width: '44px', 
                                        height: '44px', 
                                        borderRadius: '12px', 
                                        display: 'flex', 
                                        alignItems: 'center', 
                                        justifyContent: 'center',
                                        backgroundColor: '#eff6ff',
                                        color: '#3b82f6',
                                        border: 'none',
                                        cursor: 'pointer'
                                    }}>
                                    <Edit2 size={20} />
                                </button>
                                <button 
                                    onClick={() => handleDelete(slide._id)}
                                    title="Delete Slide"
                                    style={{ 
                                        width: '44px', 
                                        height: '44px', 
                                        borderRadius: '12px', 
                                        display: 'flex', 
                                        alignItems: 'center', 
                                        justifyContent: 'center',
                                        backgroundColor: '#fef2f2',
                                        color: '#ef4444',
                                        border: 'none',
                                        cursor: 'pointer'
                                    }}>
                                    <Trash2 size={20} />
                                </button>
                            </div>
                        </div>
                    ))
                )}
            </div>

            {/* Edit/Create Modal */}
            {showModal && (
                <div style={{ 
                    position: 'fixed', 
                    inset: 0, 
                    backgroundColor: 'rgba(15, 23, 42, 0.8)', 
                    backdropFilter: 'blur(8px)',
                    zIndex: 2000, 
                    display: 'flex', 
                    alignItems: 'center', 
                    justifyContent: 'center',
                    padding: '20px'
                }}>
                    <div style={{ 
                        backgroundColor: 'white', 
                        width: '100%', 
                        maxWidth: '1250px', 
                        maxHeight: '95vh', 
                        borderRadius: '32px', 
                        display: 'flex', 
                        flexDirection: 'column',
                        overflow: 'hidden',
display: 'flex',
                        boxShadow: '0 25px 50px -12px rgba(0, 0, 0, 0.5)'
                    }}>
                        {/* Modal Header */}
                        <div style={{ padding: '24px 40px', borderBottom: '1px solid #f1f5f9', display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                            <div>
                                <h2 style={{ fontSize: '20px', fontWeight: '800', color: '#1e293b' }}>{editingSlide ? 'Edit Hero Slide' : 'Create New Hero Slide'}</h2>
                                <p style={{ fontSize: '13px', color: '#64748b' }}>Configure your hero banner visuals and messaging.</p>
                            </div>
                            <div style={{ display: 'flex', gap: '12px' }}>
                                <button 
                                    onClick={() => setPreviewMode(!previewMode)}
                                    style={{ 
                                        padding: '10px 20px', 
                                        borderRadius: '12px', 
                                        fontSize: '13px', 
                                        fontWeight: '700',
                                        backgroundColor: previewMode ? 'var(--primary)' : '#f1f5f9',
                                        color: previewMode ? 'white' : '#64748b',
                                        display: 'flex',
                                        alignItems: 'center',
                                        gap: '8px'
                                    }}>
                                    <Eye size={18} /> {previewMode ? 'Edit Mode' : 'Live Preview'}
                                </button>
                                <button onClick={() => setShowModal(false)} style={{ p: '10px', borderRadius: '12px', border: 'none', backgroundColor: '#f1f5f9', color: '#64748b', cursor: 'pointer' }}>
                                    <X size={20} />
                                </button>
                            </div>
                        </div>

                        {/* Modal Body */}
                        <div style={{ flex: 1, overflowY: 'auto', padding: '40px' }}>
                            {previewMode ? (
                                /* Live Preview Panel */
                                <div style={{ 
                                    position: 'relative', 
                                    width: '100%', 
                                    height: '550px', 
                                    borderRadius: '24px', 
                                    backgroundColor: '#0f172a',
                                    backgroundImage: `url("${formData.backgroundImage}")`,
                                    backgroundSize: 'cover',
                                    backgroundPosition: 'center',
                                    overflow: 'hidden',
display: 'flex',
                                    flexDirection: 'column',
                                    justifyContent: 'center',
                                    alignItems: formData.alignment === 'center' ? 'center' : 'flex-start',
                                    padding: '80px',
                                    textAlign: formData.alignment === 'center' ? 'center' : 'left',
                                    fontFamily: formData.fontFamily || 'Outfit'
                                }}>
                                    <div style={{ position: 'absolute', inset: 0, backgroundColor: 'rgba(15, 23, 42, 0.4)', zIndex: 1 }}></div>
                                    <div style={{ position: 'relative', zIndex: 2, maxWidth: '800px' }}>
                                        <div style={{ 
                                            display: 'inline-flex', 
                                            alignItems: 'center', 
                                            gap: '8px', 
                                            padding: '8px 16px', 
                                            borderRadius: '12px', 
                                            backgroundColor: 'rgba(15, 23, 42, 0.5)', 
                                            backdropFilter: 'blur(10px)',
                                            border: '1px solid rgba(255,255,255,0.1)',
                                            color: 'white',
                                            fontSize: '10px',
                                            fontWeight: '900',
                                            textTransform: 'uppercase',
                                            letterSpacing: '2px',
                                            marginBottom: '24px'
                                        }}>
                                            <span style={{ 
                                                width: '6px', height: '6px', borderRadius: '50%', 
                                                backgroundColor: formData.accentColor === 'blue' ? '#3b82f6' : 
                                                                 formData.accentColor === 'sky' ? '#0ea5e9' : 
                                                                 formData.accentColor === 'indigo' ? '#6366f1' : '#10b981', 
                                                animation: 'pulse 2s infinite' 
                                            }}></span>
                                            {formData.badgeText || 'PROMO BADGE'}
                                        </div>
                                        <h1 style={{ 
                                            fontSize: formData.titleSize || '64px', 
                                            fontWeight: formData.titleWeight || '900', 
                                            color: formData.titleColor || 'white', 
                                            textTransform: formData.titleStyle === 'uppercase' || formData.titleStyle === 'bold-italic' ? 'uppercase' : 'none',
                                            fontStyle: formData.titleStyle === 'italic' || formData.titleStyle === 'bold-italic' ? 'italic' : 'normal',
                                            lineHeight: '1.2', 
                                            letterSpacing: '-1px',
                                            marginBottom: '24px'
                                        }}>
                                            {formData.title.split(' ').map((word, i) => (
                                                <span key={i} style={{ 
                                                    color: (word === formData.titleHighlight) ? (formData.highlightColor || '#10b981') : 'inherit', 
                                                    marginRight: '12px' 
                                                }}>
                                                    {word}
                                                </span>
                                            ))}
                                        </h1>

                                        <p style={{ 
                                            fontSize: formData.subtitleSize || '18px', 
                                            color: formData.subtitleColor || 'rgba(255,255,255,0.8)', 
                                            lineHeight: '1.6', 
                                            marginBottom: '40px',
                                            maxWidth: '500px'
                                        }}>
                                            {formData.subtitle}
                                        </p>
                                        <div style={{ display: 'flex', gap: '16px' }}>
                                            <button style={{ 
                                                padding: '16px 32px', 
                                                borderRadius: '12px', 
                                                backgroundColor: formData.buttonColor || 'var(--primary)', 
                                                color: 'white', 
                                                fontWeight: '800', 
                                                fontSize: '12px', 
                                                textTransform: 'uppercase',
                                                border: 'none',
                                                boxShadow: `0 10px 20px -5px ${formData.buttonColor || 'var(--primary)'}66`
                                            }}>{formData.primaryButtonText}</button>
                                            <button style={{ 
                                                padding: '16px 32px', 
                                                borderRadius: '12px', 
                                                backgroundColor: 'rgba(255,255,255,0.1)', 
                                                backdropFilter: 'blur(10px)',
                                                border: '1px solid rgba(255,255,255,0.1)',
                                                color: 'white', 
                                                fontWeight: '800', 
                                                fontSize: '12px', 
                                                textTransform: 'uppercase'
                                            }}>{formData.secondaryButtonText}</button>
                                        </div>
                                    </div>
                                    <div style={{ position: 'absolute', bottom: '40px', right: '40px', zIndex: 2 }}>
                                        <span style={{ fontSize: '10px', fontWeight: '900', color: 'rgba(255,255,255,0.4)', textTransform: 'uppercase', letterSpacing: '2px' }}>{formData.supportStripText}</span>
                                    </div>
                                </div>
                            ) : (
                                <form onSubmit={handleSubmit} style={{ display: 'grid', gridTemplateColumns: 'repeat(2, 1fr)', gap: '40px' }}>
                                    {/* Left Column: Visuals & Settings */}
                                    <div style={{ display: 'flex', flexDirection: 'column', gap: '32px' }}>
                                        <div style={{ backgroundColor: '#f8fafc', padding: '32px', borderRadius: '24px', border: '1px solid #f1f5f9' }}>
                                            <label style={{ display: 'block', marginBottom: '20px', fontWeight: '800', fontSize: '14px', color: '#1e293b' }}>Background Visual</label>
                                            <div style={{ marginBottom: '20px' }}>
                                                <div style={{ 
                                                    width: '100%', 
                                                    height: '200px', 
                                                    borderRadius: '16px', 
                                                    backgroundColor: '#f1f5f9', 
                                                    backgroundImage: formData.backgroundImage ? `url("${formData.backgroundImage}")` : 'none',
                                                    backgroundSize: 'cover',
                                                    backgroundPosition: 'center',
                                                    backgroundRepeat: 'no-repeat',
                                                    display: 'flex',
                                                    alignItems: 'center',
                                                    justifyContent: 'center',
                                                    border: '2px dashed #e2e8f0',
                                                    marginBottom: '16px',
                                                    position: 'relative',
                                                    overflow: 'hidden'
                                                }}>
                                                    {uploading ? (
                                                        <div style={{ textAlign: 'center' }}>
                                                            <div className="animate-spin" style={{ width: '24px', height: '24px', border: '3px solid var(--primary)', borderTopColor: 'transparent', borderRadius: '50%', margin: '0 auto 10px' }}></div>
                                                            <span style={{ fontSize: '12px', fontWeight: '700', color: 'var(--primary)' }}>Uploading...</span>
                                                        </div>
                                                    ) : !formData.backgroundImage ? (
                                                        <div style={{ textAlign: 'center' }}>
                                                            <ImageIcon size={32} color="#cbd5e1" />
                                                            <p style={{ fontSize: '11px', color: '#94a3b8', marginTop: '8px' }}>No image selected</p>
                                                        </div>
                                                    ) : null}
                                                    
                                                    <label style={{ 
                                                        position: 'absolute', 
                                                        inset: 0, 
                                                        cursor: 'pointer',
                                                        display: 'flex',
                                                        alignItems: 'center',
                                                        justifyContent: 'center',
                                                        backgroundColor: 'rgba(15, 23, 42, 0)',
                                                        transition: 'all 0.3s ease'
                                                    }} onMouseOver={(e) => e.currentTarget.style.backgroundColor = 'rgba(15, 23, 42, 0.4)'} onMouseOut={(e) => e.currentTarget.style.backgroundColor = 'rgba(15, 23, 42, 0)'}>
                                                        <input type="file" style={{ display: 'none' }} onChange={handleFileUpload} accept="image/*" />
                                                        <div style={{ 
                                                            display: 'flex', 
                                                            flexDirection: 'column', 
                                                            alignItems: 'center', 
                                                            gap: '8px',
                                                            opacity: 0,
                                                            transition: 'opacity 0.3s'
                                                        }} className="upload-label">
                                                            <Plus size={24} color="white" />
                                                            <span style={{ color: 'white', fontSize: '11px', fontWeight: '800', textTransform: 'uppercase' }}>{formData.backgroundImage ? 'Replace Image' : 'Upload Image'}</span>
                                                        </div>
                                                        <style>{`.upload-label { opacity: 0; } label:hover .upload-label { opacity: 1; }`}</style>
                                                    </label>
                                                </div>
                                                <div style={{ display: 'flex', flexDirection: 'column', gap: '8px' }}>
                                                    <label style={{ fontSize: '11px', fontWeight: '800', color: '#64748b', textTransform: 'uppercase' }}>Or enter Image URL</label>
                                                    <input 
                                                        type="text" 
                                                        placeholder="https://example.com/image.jpg" 
                                                        value={formData.backgroundImage}
                                                        onChange={(e) => setFormData({ ...formData, backgroundImage: e.target.value })}
                                                        style={{ width: '100%', padding: '14px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }}
                                                    />
                                                </div>
                                            </div>
                                            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '16px' }}>
                                                <div>
                                                    <label style={{ display: 'block', marginBottom: '8px', fontSize: '12px', fontWeight: '700', color: '#64748b' }}>Accent Color</label>
                                                    <select 
                                                        value={formData.accentColor}
                                                        onChange={(e) => setFormData({ ...formData, accentColor: e.target.value })}
                                                        style={{ width: '100%', padding: '12px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }}>
                                                        <option value="emerald">Emerald Green</option>
                                                        <option value="blue">Banking Blue</option>
                                                        <option value="sky">Premium Sky</option>
                                                        <option value="indigo">Investment Indigo</option>
                                                    </select>
                                                </div>
                                                <div>
                                                    <label style={{ display: 'block', marginBottom: '8px', fontSize: '12px', fontWeight: '700', color: '#64748b' }}>Premium Font</label>
                                                    <select 
                                                        value={formData.fontFamily}
                                                        onChange={(e) => setFormData({ ...formData, fontFamily: e.target.value })}
                                                        style={{ width: '100%', padding: '12px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }}>
                                                        <option value="Outfit">Outfit (Modem & Bold)</option>
                                                        <option value="Inter">Inter (Clean & Professional)</option>
                                                        <option value="Manrope">Manrope (Fintech Sleek)</option>
                                                        <option value="Roboto">Roboto (Classic Info)</option>
                                                    </select>
                                                </div>
                                                <div>
                                                    <label style={{ display: 'block', marginBottom: '8px', fontSize: '12px', fontWeight: '700', color: '#64748b' }}>Text Casing / Style</label>
                                                    <select 
                                                        value={formData.titleStyle}
                                                        onChange={(e) => setFormData({ ...formData, titleStyle: e.target.value })}
                                                        style={{ width: '100%', padding: '12px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }}>
                                                        <option value="uppercase">Uppercase Bold</option>
                                                        <option value="bold-italic">Uppercase Italic</option>
                                                        <option value="italic">Normal Italic</option>
                                                        <option value="normal">Standard (Sentence)</option>
                                                    </select>
                                                </div>
                                                <div>
                                                    <label style={{ display: 'block', marginBottom: '8px', fontSize: '12px', fontWeight: '700', color: '#64748b' }}>Alignment</label>
                                                    <select 
                                                        value={formData.alignment}
                                                        onChange={(e) => setFormData({ ...formData, alignment: e.target.value })}
                                                        style={{ width: '100%', padding: '12px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }}>
                                                        <option value="left">Left Aligned</option>
                                                        <option value="center">Center Aligned</option>
                                                    </select>
                                                </div>
                                                <div>
                                                    <label style={{ display: 'block', marginBottom: '8px', fontSize: '12px', fontWeight: '700', color: '#64748b' }}>Visual Mode</label>
                                                    <select 
                                                        value={formData.visualMode}
                                                        onChange={(e) => setFormData({ ...formData, visualMode: e.target.value })}
                                                        style={{ width: '100%', padding: '12px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }}>
                                                        <option value="standard">Standard Overlay</option>
                                                        <option value="3d">3D Depth Effect</option>
                                                        <option value="minimal">Minimalist</option>
                                                    </select>
                                                </div>
                                            </div>

                                            <div style={{ borderTop: '1px solid #f1f5f9', paddingTop: '30px', marginTop: '10px' }}>
                                                <h4 style={{ fontSize: '14px', fontWeight: '800', color: '#1e293b', marginBottom: '20px', display: 'flex', alignItems: 'center', gap: '10px' }}>
                                                    <Sparkles size={18} color="var(--primary)" /> Advanced Styling Controls
                                                </h4>
                                                <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: '20px' }}>
                                                    <div>
                                                        <label style={{ display: 'block', marginBottom: '8px', fontSize: '11px', fontWeight: '700', color: '#64748b', textTransform: 'uppercase' }}>Title Size</label>
                                                        <select value={formData.titleSize} onChange={(e) => setFormData({ ...formData, titleSize: e.target.value })} style={{ width: '100%', padding: '10px', borderRadius: '10px', border: '1px solid #e2e8f0', fontSize: '12px' }}>
                                                            <option value="48px">Small (48px)</option>
                                                            <option value="64px">Medium (64px)</option>
                                                            <option value="84px">Large (84px)</option>
                                                            <option value="114px">Extra Large (114px)</option>
                                                        </select>
                                                    </div>
                                                    <div>
                                                        <label style={{ display: 'block', marginBottom: '8px', fontSize: '11px', fontWeight: '700', color: '#64748b', textTransform: 'uppercase' }}>Subtitle Size</label>
                                                        <select value={formData.subtitleSize} onChange={(e) => setFormData({ ...formData, subtitleSize: e.target.value })} style={{ width: '100%', padding: '10px', borderRadius: '10px', border: '1px solid #e2e8f0', fontSize: '12px' }}>
                                                            <option value="14px">Small (14px)</option>
                                                            <option value="18px">Medium (18px)</option>
                                                            <option value="22px">Large (22px)</option>
                                                        </select>
                                                    </div>
                                                    <div>
                                                        <label style={{ display: 'block', marginBottom: '8px', fontSize: '11px', fontWeight: '700', color: '#64748b', textTransform: 'uppercase' }}>Motion Effect</label>
                                                        <select value={formData.motionType} onChange={(e) => setFormData({ ...formData, motionType: e.target.value })} style={{ width: '100%', padding: '10px', borderRadius: '10px', border: '1px solid #e2e8f0', fontSize: '12px' }}>
                                                            <option value="slide-up">Slide Up</option>
                                                            <option value="fade">Fade In</option>
                                                            <option value="zoom-in">Zoom In</option>
                                                            <option value="none">No Motion</option>
                                                        </select>
                                                    </div>
                                                    <div>
                                                        <label style={{ display: 'block', marginBottom: '8px', fontSize: '11px', fontWeight: '700', color: '#64748b', textTransform: 'uppercase' }}>Title Color</label>
                                                        <div style={{ display: 'flex', gap: '8px' }}>
                                                            <input type="color" value={formData.titleColor} onChange={(e) => setFormData({ ...formData, titleColor: e.target.value })} style={{ width: '40px', height: '40px', padding: '2px', borderRadius: '8px', border: '1px solid #e2e8f0', cursor: 'pointer' }} />
                                                            <input type="text" value={formData.titleColor} onChange={(e) => setFormData({ ...formData, titleColor: e.target.value })} style={{ flex: 1, padding: '10px', borderRadius: '10px', border: '1px solid #e2e8f0', fontSize: '12px' }} />
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <label style={{ display: 'block', marginBottom: '8px', fontSize: '11px', fontWeight: '700', color: '#64748b', textTransform: 'uppercase' }}>Highlight Color</label>
                                                        <div style={{ display: 'flex', gap: '8px' }}>
                                                            <input type="color" value={formData.highlightColor} onChange={(e) => setFormData({ ...formData, highlightColor: e.target.value })} style={{ width: '40px', height: '40px', padding: '2px', borderRadius: '8px', border: '1px solid #e2e8f0', cursor: 'pointer' }} />
                                                            <input type="text" value={formData.highlightColor} onChange={(e) => setFormData({ ...formData, highlightColor: e.target.value })} style={{ flex: 1, padding: '10px', borderRadius: '10px', border: '1px solid #e2e8f0', fontSize: '12px' }} />
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <label style={{ display: 'block', marginBottom: '8px', fontSize: '11px', fontWeight: '700', color: '#64748b', textTransform: 'uppercase' }}>Button Color</label>
                                                        <div style={{ display: 'flex', gap: '8px' }}>
                                                            <input type="color" value={formData.buttonColor} onChange={(e) => setFormData({ ...formData, buttonColor: e.target.value })} style={{ width: '40px', height: '40px', padding: '2px', borderRadius: '8px', border: '1px solid #e2e8f0', cursor: 'pointer' }} />
                                                            <input type="text" value={formData.buttonColor} onChange={(e) => setFormData({ ...formData, buttonColor: e.target.value })} style={{ flex: 1, padding: '10px', borderRadius: '10px', border: '1px solid #e2e8f0', fontSize: '12px' }} />
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div style={{ backgroundColor: '#f8fafc', padding: '32px', borderRadius: '24px', border: '1px solid #f1f5f9' }}>
                                            <label style={{ display: 'block', marginBottom: '20px', fontWeight: '800', fontSize: '14px', color: '#1e293b' }}>Display Controls</label>
                                            <div style={{ display: 'grid', gap: '16px' }}>
                                                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                                                    <div>
                                                        <span style={{ fontSize: '13px', fontWeight: '700', color: '#475569' }}>Active Status</span>
                                                        <p style={{ fontSize: '11px', color: '#94a3b8' }}>Show this slide on the homepage.</p>
                                                    </div>
                                                    <input type="checkbox" checked={formData.isActive} onChange={(e) => setFormData({ ...formData, isActive: e.target.checked })} style={{ width: '20px', height: '20px', accentColor: 'var(--primary)' }} />
                                                </div>
                                                <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center' }}>
                                                    <div>
                                                        <span style={{ fontSize: '13px', fontWeight: '700', color: '#475569' }}>Animations</span>
                                                        <p style={{ fontSize: '11px', color: '#94a3b8' }}>Enable floating text and BG motion.</p>
                                                    </div>
                                                    <input type="checkbox" checked={formData.animationEnabled} onChange={(e) => setFormData({ ...formData, animationEnabled: e.target.checked })} style={{ width: '20px', height: '20px', accentColor: 'var(--primary)' }} />
                                                </div>
                                                <div>
                                                    <label style={{ display: 'block', marginBottom: '8px', fontSize: '12px', fontWeight: '700', color: '#64748b' }}>Display Order</label>
                                                    <input 
                                                        type="number" 
                                                        value={formData.order} 
                                                        onChange={(e) => setFormData({ ...formData, order: parseInt(e.target.value) })}
                                                        style={{ width: '100%', padding: '12px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }} 
                                                    />
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    {/* Right Column: Content & Messaging */}
                                    <div style={{ display: 'flex', flexDirection: 'column', gap: '32px' }}>
                                        <div style={{ display: 'flex', flexDirection: 'column', gap: '20px' }}>
                                            <div>
                                                <label style={{ display: 'block', marginBottom: '10px', fontSize: '13px', fontWeight: '800', color: '#1e293b' }}>Top Badge Text</label>
                                                <input 
                                                    type="text" 
                                                    placeholder="e.g. INSTITUTIONAL STABILITY" 
                                                    value={formData.badgeText}
                                                    onChange={(e) => setFormData({ ...formData, badgeText: e.target.value })}
                                                    style={{ width: '100%', padding: '14px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }}
                                                />
                                            </div>
                                            <div>
                                                <label style={{ display: 'block', marginBottom: '10px', fontSize: '13px', fontWeight: '800', color: '#1e293b' }}>Hero Main Title</label>
                                                <input 
                                                    type="text" 
                                                    placeholder="Enter bold title..." 
                                                    value={formData.title}
                                                    onChange={(e) => setFormData({ ...formData, title: e.target.value })}
                                                    style={{ width: '100%', padding: '14px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }}
                                                    required
                                                />
                                            </div>
                                            <div>
                                                <label style={{ display: 'block', marginBottom: '10px', fontSize: '13px', fontWeight: '800', color: '#1e293b' }}>Highlight Word</label>
                                                <input 
                                                    type="text" 
                                                    placeholder="Word to highlight with accent color..." 
                                                    value={formData.titleHighlight}
                                                    onChange={(e) => setFormData({ ...formData, titleHighlight: e.target.value })}
                                                    style={{ width: '100%', padding: '14px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }}
                                                />
                                            </div>
                                            <div>
                                                <label style={{ display: 'block', marginBottom: '10px', fontSize: '13px', fontWeight: '800', color: '#1e293b' }}>Subtitle / Description</label>
                                                <textarea 
                                                    rows="3" 
                                                    placeholder="Enter descriptive text..." 
                                                    value={formData.subtitle}
                                                    onChange={(e) => setFormData({ ...formData, subtitle: e.target.value })}
                                                    style={{ width: '100%', padding: '14px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px', resize: 'none' }}
                                                    required
                                                ></textarea>
                                            </div>
                                        </div>

                                        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '20px' }}>
                                            <div>
                                                <label style={{ display: 'block', marginBottom: '10px', fontSize: '13px', fontWeight: '800', color: '#1e293b' }}>Primary CTA Text</label>
                                                <input 
                                                    type="text" 
                                                    value={formData.primaryButtonText}
                                                    onChange={(e) => setFormData({ ...formData, primaryButtonText: e.target.value })}
                                                    style={{ width: '100%', padding: '14px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }} 
                                                />
                                            </div>
                                            <div>
                                                <label style={{ display: 'block', marginBottom: '10px', fontSize: '13px', fontWeight: '800', color: '#1e293b' }}>Primary Link</label>
                                                <input 
                                                    type="text" 
                                                    value={formData.primaryButtonLink}
                                                    onChange={(e) => setFormData({ ...formData, primaryButtonLink: e.target.value })}
                                                    style={{ width: '100%', padding: '14px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }} 
                                                />
                                            </div>
                                            <div>
                                                <label style={{ display: 'block', marginBottom: '10px', fontSize: '13px', fontWeight: '800', color: '#1e293b' }}>Secondary CTA Text</label>
                                                <input 
                                                    type="text" 
                                                    value={formData.secondaryButtonText}
                                                    onChange={(e) => setFormData({ ...formData, secondaryButtonText: e.target.value })}
                                                    style={{ width: '100%', padding: '14px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }} 
                                                />
                                            </div>
                                            <div>
                                                <label style={{ display: 'block', marginBottom: '10px', fontSize: '13px', fontWeight: '800', color: '#1e293b' }}>Secondary Link</label>
                                                <input 
                                                    type="text" 
                                                    value={formData.secondaryButtonLink}
                                                    onChange={(e) => setFormData({ ...formData, secondaryButtonLink: e.target.value })}
                                                    style={{ width: '100%', padding: '14px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }} 
                                                />
                                            </div>
                                        </div>

                                        <div>
                                            <label style={{ display: 'block', marginBottom: '10px', fontSize: '13px', fontWeight: '800', color: '#1e293b' }}>Trust / Support Strip Text</label>
                                            <input 
                                                type="text" 
                                                placeholder="e.g. Registered in Sri Lanka No: PV 003..." 
                                                value={formData.supportStripText}
                                                onChange={(e) => setFormData({ ...formData, supportStripText: e.target.value })}
                                                style={{ width: '100%', padding: '14px', borderRadius: '12px', border: '1px solid #e2e8f0', fontSize: '13px' }}
                                            />
                                        </div>
                                    </div>
                                </form>
                            )}
                        </div>

                        {/* Modal Footer */}
                        <div style={{ padding: '24px 40px', borderTop: '1px solid #f1f5f9', display: 'flex', justifyContent: 'flex-end', gap: '16px', backgroundColor: '#f8fafc' }}>
                            <button onClick={() => setShowModal(false)} className="btn-secondary" style={{ padding: '12px 24px', borderRadius: '12px' }}>Cancel</button>
                            {!previewMode && (
                                <button 
                                    onClick={handleSubmit}
                                    style={{ 
                                        backgroundColor: 'var(--primary)', 
                                        color: 'white', 
                                        padding: '12px 32px', 
                                        borderRadius: '12px', 
                                        fontWeight: '800',
                                        display: 'flex',
                                        alignItems: 'center',
                                        gap: '8px',
                                        fontSize: '14px',
                                        border: 'none',
                                        cursor: 'pointer'
                                    }}>
                                    <Save size={18} /> {editingSlide ? 'Update Hero Slide' : 'Publish Hero Slide'}
                                </button>
                            )}
                        </div>
                    </div>
                </div>
            )}
            {/* Final Confirmation Popup */}
            {showConfirmPopup && (
                <div style={{ 
                    position: 'fixed', 
                    inset: 0, 
                    backgroundColor: 'rgba(15, 23, 42, 0.9)', 
                    backdropFilter: 'blur(12px)',
                    zIndex: 3000, 
                    display: 'flex', 
                    alignItems: 'center', 
                    justifyContent: 'center',
                    padding: '20px'
                }}>
                    <div style={{ 
                        backgroundColor: 'white', 
                        width: '100%', 
                        maxWidth: '450px', 
                        borderRadius: '24px', 
                        padding: '32px',
                        textAlign: 'center',
                        boxShadow: '0 25px 50px -12px rgba(0, 0, 0, 0.5)'
                    }}>
                        <div style={{ 
                            width: '64px', 
                            height: '64px', 
                            borderRadius: '50%', 
                            backgroundColor: 'rgba(16, 185, 129, 0.1)', 
                            color: 'var(--primary)',
                            display: 'flex',
                            alignItems: 'center',
                            justifyContent: 'center',
                            margin: '0 auto 24px'
                        }}>
                            <ShieldCheck size={32} />
                        </div>
                        <h3 style={{ fontSize: '20px', fontWeight: '800', color: '#1e293b', marginBottom: '12px' }}>Verify Publication</h3>
                        <p style={{ fontSize: '14px', color: '#64748b', marginBottom: '24px', lineHeight: '1.5' }}>
                            You are about to update the main hero area of the customer website. This is a critical action. 
                            Please type <strong style={{ color: '#1e293b' }}>"confirm"</strong> in the box below to proceed.
                        </p>
                        
                        <input 
                            type="text" 
                            placeholder="Type confirm here..." 
                            value={confirmationInput}
                            onChange={(e) => setConfirmationInput(e.target.value)}
                            style={{ 
                                width: '100%', 
                                padding: '14px', 
                                textAlign: 'center',
                                borderRadius: '12px', 
                                border: '2px solid #e2e8f0', 
                                fontSize: '15px',
                                fontWeight: '700',
                                marginBottom: '24px',
                                outline: 'none',
                                transition: 'all 0.2s',
                                borderColor: confirmationInput.toLowerCase() === 'confirm' ? 'var(--primary)' : '#e2e8f0'
                            }}
                            autoFocus
                        />

                        <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '12px' }}>
                            <button 
                                onClick={() => setShowConfirmPopup(false)}
                                style={{ 
                                    padding: '12px', 
                                    borderRadius: '12px', 
                                    border: 'none', 
                                    backgroundColor: '#f1f5f9', 
                                    color: '#64748b', 
                                    fontWeight: '700',
                                    cursor: 'pointer'
                                }}>
                                Cancel
                            </button>
                            <button 
                                onClick={handleFinalConfirm}
                                disabled={confirmationInput.toLowerCase() !== 'confirm'}
                                style={{ 
                                    padding: '12px', 
                                    borderRadius: '12px', 
                                    border: 'none', 
                                    backgroundColor: confirmationInput.toLowerCase() === 'confirm' ? 'var(--primary)' : '#cbd5e1', 
                                    color: 'white', 
                                    fontWeight: '800',
                                    cursor: confirmationInput.toLowerCase() === 'confirm' ? 'pointer' : 'not-allowed'
                                }}>
                                Confirm & Publish
                            </button>
                        </div>
                    </div>
                </div>
            )}
        </div>
    );
};

export default HeroManagement;
